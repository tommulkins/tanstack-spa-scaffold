{
  "name": "tanstack-spa-scaffold",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @scaffold/web --filter @scaffold/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "prettier --check . && eslint .",
    "analyze": "fallow audit --format json",
    "analyze:report": "fallow dead-code && fallow health --score --hotspots",
    "format": "prettier --write .",
    "test:unit": "pnpm -r test:unit",
    "test": "node scripts/run-e2e.mjs",
    "test:all": "pnpm test:unit && pnpm test",
    "test:agent-policy": "bash scripts/check-agent-suppressions.test.sh",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.16.5",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fallow": "^2.101.0",
    "globals": "^16.3.0",
    "lefthook": "^2.1.5",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.38.0"
  }
}
